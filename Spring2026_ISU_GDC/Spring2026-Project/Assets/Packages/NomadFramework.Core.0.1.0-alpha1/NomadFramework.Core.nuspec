        <dependency id="System.IO.Hashing" version="10.0.3" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.1">
        <dependency id="Microsoft.IO.RecyclableMemoryStream" version="3.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Collections.Immutable" version="10.0.3" exclude="Build,Analyzers" />
        <dependency id="System.IO.Hashing" version="10.0.3" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
