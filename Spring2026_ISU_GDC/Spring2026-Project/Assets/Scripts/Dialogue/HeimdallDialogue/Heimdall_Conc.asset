  m_Script: {fileID: 11500000, guid: b6198cdbfb3ab42799698812d172dc50, type: 3}
  m_Name: Heimdall_Conc
  m_EditorClassIdentifier: Assembly-CSharp::ISUGameDev.SpearGame.Dialogue.Dialogue
  dialogueStrings:
  - I did not lose faith in you for a second, my lady.
  - '[r]The 9 realms have been saved, thanks to you.'
  - '[v]As I said, it is my duty. Seeing the realms thrive is the only reward I hope
    for.'
  - I am sure Loki will not be the last, but now is not the time to think of such
    things.
  - I believe peace is upon us.
  - '[v]Peace well earned.'
  - '[v]I have hopes that without their strongest, this war will fizzle out.'
  - "Well then. If that\u2019s the case, I suppose there\u2019s not much left to
    do here."
  - "[v]I gather you are correct. So\u2026"
  - '[v]Where to next?'
  characterIcon: {fileID: 5409877374513879306, guid: 6c7e76d0462c03742a67d9f5ebc3cffa, type: 3}
  characterName: Heimdall & Ratatoskr
